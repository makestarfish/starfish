{
  "db_name": "PostgreSQL",
  "query": "\n      select a.id, a.stripe_id, a.status as \"status: AccountStatus\"\n      from accounts a\n      where \n        a.store_id = $1 and\n        exists (\n          select 1\n          from store_members sm\n          where a.store_id = sm.store_id and sm.user_id = $2\n        )\n    ",
