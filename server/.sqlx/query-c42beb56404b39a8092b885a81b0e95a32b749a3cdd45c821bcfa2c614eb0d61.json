  "db_name": "PostgreSQL",
  "query": "\n      select \n        s.id, \n        s.slug, \n        s.name, \n        s.status as \"status: StoreStatus\",\n        s.email, \n        s.website, \n        s.avatar_url, \n        s.created_at, \n        s.modified_at\n      from stores s\n      where \n        exists (\n          select 1\n          from store_members sm\n          where s.id = sm.store_id and sm.user_id = $1\n        )\n    ",
