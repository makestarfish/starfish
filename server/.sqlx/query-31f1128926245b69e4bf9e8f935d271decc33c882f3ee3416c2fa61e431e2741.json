  "query": "\n      select id, store_id, email, name, avatar_url, created_at, modified_at\n      from customers\n      where \n        store_id = $1 and\n        deleted_at is null and\n        (id < $2 or $2 is null) and \n        (id > $3 or $3 is null)\n      order by id desc\n      limit 20\n    ",
