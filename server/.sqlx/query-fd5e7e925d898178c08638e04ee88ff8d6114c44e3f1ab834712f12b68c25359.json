{
  "db_name": "PostgreSQL",
  "query": "\n      select \n        t.id, \n        t.incurred_by as \"incurred_by: TransactionId\",\n        t.account_id,\n        t.order_id, \n        t.amount, \n        t.incurred_amount, \n        (t.amount + t.incurred_amount) as \"net_amount!\",\n        t.created_at,\n        t.modified_at\n      from transactions t\n      join accounts a on t.account_id = a.id\n      where \n        t.id = $1 and\n        exists (\n          select 1\n          from store_members sm\n          where sm.store_id = a.store_id and sm.user_id = $2\n        )\n    ",
