{
  "db_name": "PostgreSQL",
  "query": "\n      select \n        c.id, \n        c.store_id, \n        c.email, \n        c.name, \n        c.avatar_url, \n        c.created_at, \n        c.modified_at\n      from customers c\n      where c.id = $1 and exists (\n        select 1\n        from store_members sm\n        where sm.store_id = c.store_id and sm.user_id = $2\n      )\n    ",
