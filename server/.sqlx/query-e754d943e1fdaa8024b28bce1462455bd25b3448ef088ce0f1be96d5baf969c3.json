{
  "db_name": "PostgreSQL",
  "query": "\n      select \n        p.id, \n        p.store_id, \n        p.name, \n        p.description, \n        p.archived, \n        p.created_at, \n        p.modified_at\n      from products p\n      where \n        id = $1 and\n        exists (\n          select 1\n          from store_members sm\n          where sm.store_id = p.store_id and sm.user_id = $2\n        )\n    ",
