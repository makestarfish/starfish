  "query": "\n      select id, store_id, name, description, archived, created_at, modified_at\n      from products\n      where \n        store_id = $1 and \n        archived = $2 and\n        (id < $3 or $3 is null) and\n        (id > $4 or $4 is null)\n      order by id desc\n      limit 20\n    ",
