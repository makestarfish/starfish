{
  "db_name": "PostgreSQL",
  "query": "\n      select\n        si.id, \n        si.store_id,\n        si.email, \n        si.accepted_at, \n        si.revoked_at, \n        si.created_at, \n        si.modified_at\n      from store_invites si\n      where si.id = $1 and exists (\n        select 1\n        from store_members sm\n        where sm.store_id = si.store_id and sm.user_id = $2\n      )\n    ",
