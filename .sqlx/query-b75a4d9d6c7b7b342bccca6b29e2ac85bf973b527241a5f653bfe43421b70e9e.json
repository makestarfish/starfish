  "query": "\n      select \n        r.revoked as refresh_token_revoked, \n        s.id as session_id, \n        s.user_id as session_user_id,\n        s.revoked as session_revoked\n      from refresh_tokens r\n      join sessions s on r.session_id = s.id\n      where r.id = $1\n    ",
