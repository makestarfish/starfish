{
  "db_name": "PostgreSQL",
  "query": "\n      select id, store_id, email, revoked_at, accepted_at, created_at, modified_at\n      from store_invites\n      where \n        store_id = $1 and\n        (revoked_at is not null) = $2 and\n        (id < $3 or $3 is null) and \n        (id > $4 or $4 is null)\n      order by id desc\n      limit 20\n    ",
