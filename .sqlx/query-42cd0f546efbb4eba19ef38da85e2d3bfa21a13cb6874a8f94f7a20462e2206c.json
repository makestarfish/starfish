{
  "db_name": "PostgreSQL",
  "query": "\n      select \n        cl.id, \n        cl.store_id, \n        cl.client_secret, \n        cl.label, \n        cl.success_url, \n        rtrim($3, '/') || '/links/' || cl.client_secret as \"url!\",\n        cl.created_at, \n        cl.modified_at\n      from checkout_links cl\n      where \n        cl.id = $1 and \n        exists (\n          select 1\n          from store_members sm\n          where sm.store_id = cl.store_id and user_id = $2\n        )\n    ",
