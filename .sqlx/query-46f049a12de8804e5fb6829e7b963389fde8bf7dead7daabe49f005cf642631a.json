{
  "db_name": "PostgreSQL",
  "query": "\n      select \n        id, \n        store_id, \n        client_secret,\n        label, \n        success_url,\n        rtrim($4, '/') || '/links/' || client_secret as \"url!\",\n        created_at,\n        modified_at\n      from checkout_links\n      where \n        store_id = $1 and\n        (id < $2 or $2 is null) and \n        (id > $3 or $3 is null)\n    ",
