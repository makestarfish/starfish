  "query": "\n      select \n        id,\n        slug,\n        name,\n        status as \"status: StoreStatus\",\n        email,\n        website,\n        avatar_url,\n        created_at,\n        modified_at,\n        exists (\n          select 1\n          from store_members sm\n          where sm.store_id = s.id and sm.user_id = $2\n        ) as member_exists\n      from stores s\n      where s.slug = $1\n    ",
